{
  "name": "goodreader",
  "module": "server/src/index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev:server": "bun run --watch server/src/index.ts",
    "dev:client": "cd client && bun run dev",
    "dev": "bun run dev:server & bun run dev:client",
    "db:generate": "bunx drizzle-kit generate",
    "db:migrate": "bunx drizzle-kit migrate",
    "db:studio": "bunx drizzle-kit studio",
    "build": "cd client && bun run build"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "drizzle-kit": "^0.31.10"
  },
  "peerDependencies": {
    "typescript": "^5"
  },
  "dependencies": {
    "@hono/node-server": "^1.19.11",
    "@mozilla/readability": "^0.6.0",
    "better-sqlite3": "^12.8.0",
    "drizzle-orm": "^0.45.1",
    "feedsmith": "^2.9.1",
    "hono": "^4.12.9",
    "linkedom": "^0.18.12"
  }
}
